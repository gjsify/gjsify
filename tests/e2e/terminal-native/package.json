{
    "name": "@gjsify/e2e-terminal-native",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "gjsify build src/probe.ts --app gjs --outfile dist/probe.gjs.mjs",
        "test": "npm run build && node run.mjs",
        "test:without": "npm run build && SKIP_NATIVE=1 node run.mjs",
        "test:with": "npm run build && node run.mjs"
    },
    "dependencies": {
        "@gjsify/process": "workspace:^",
        "@gjsify/terminal-native": "workspace:^",
        "@gjsify/tty": "workspace:^"
    },
    "devDependencies": {
        "@gjsify/cli": "workspace:^",
        "@types/node": "^25.6.2"
    }
}
