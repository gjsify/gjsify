{
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}",
    "requireCleanWorkingDir": true,
    "requireBranch": "main"
  },
  "github": {
    "release": true,
    "releaseName": "v${version}",
    "preRelease": true,
    "autoGenerate": false
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "after:bump": "node scripts/bump-docs-version.mjs ${latestVersion} ${version} && gjsify workspace @gjsify/cli build && gjsify workspace @gjsify/cli build:gjs-bundle && git add packages/infra/cli/dist/cli.gjs.mjs"
  },
  "plugins": {
    "@release-it/bumper": {
      "out": [
        "packages/*/*/package.json",
        "examples/*/*/package.json",
        "showcases/*/*/package.json",
        "website/package.json"
      ]
    },
    "@release-it/conventional-changelog": {
      "preset": {
        "name": "conventionalcommits"
      },
      "infile": "CHANGELOG.md",
      "header": "# Changelog"
    }
  }
}
