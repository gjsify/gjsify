        "@girs/gtk-4.0": "^4.23.0-4.0.0-rc.5",
        "@gjsify/cli": "workspace:^",
        "@gjsify/esbuild-plugin-blueprint": "workspace:^",
        "@types/node": "^25.6.0",
        "typescript": "^6.0.3"
    },
    "dependencies": {
