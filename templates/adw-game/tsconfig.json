{
    "compilerOptions": {
        "rootDir": "src",
        "outDir": "dist",
        "target": "ESNext",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "types": [
            "node",
            "@girs/gjs",
            "@girs/gtk-4.0",
            "@girs/adw-1",
            "@gjsify/esbuild-plugin-blueprint/types"
        ],
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true
    },
    "include": ["src"]
}
