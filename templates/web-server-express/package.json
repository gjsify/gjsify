{
    "name": "@gjsify/template-web-server-express",
    "description": "HTTP server using Express (familiar Node.js stack).",
    "version": "0.1.10",
    "type": "module",
    "private": true,
    "scripts": {
        "check": "tsc --noEmit",
        "build": "gjsify build src/index.ts --outfile dist/index.js",
        "start": "gjsify run dist/index.js",
        "dev": "gjsify build src/index.ts --outfile dist/index.js && gjsify run dist/index.js"
    },
    "devDependencies": {
        "@gjsify/cli": "workspace:^",
        "@gjsify/node-globals": "workspace:^",
        "@gjsify/runtime": "workspace:^",
        "@types/express": "^5.0.6",
        "@types/node": "^25.6.0",
        "typescript": "^6.0.3"
    },
    "dependencies": {
        "express": "^5.2.1"
    }
}
