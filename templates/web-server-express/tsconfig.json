    "compilerOptions": {
        "rootDir": "src",
        "outDir": "dist",
        "target": "ESNext",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "types": ["node"],
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true
