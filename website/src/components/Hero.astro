---
// Custom Hero component — replaces Starlight's default Hero.
// Renders the interactive Adwaita + Three.js teapot demo as the hero element.
import '@fontsource/coming-soon';
import DemoArrow from '../assets/demo-arrow.svg?raw';
---

<div class="hero-custom">
  <div class="hero-text">
    <h1 id="_top" data-page-title>GJSify</h1>
  </div>

  <div class="demo-annotation" aria-hidden="true">
    <span class="demo-annotation-text">This WebGL demo runs<br>natively on Linux</span>
    <Fragment set:html={DemoArrow} />
  </div>

  <div class="hero-demo" id="pixel-demo"></div>

  <script>
    import { mount } from '@gjsify/example-dom-three-postprocessing-pixel/browser';

    const container = document.getElementById('pixel-demo');
    if (container) {
      const base = import.meta.env.BASE_URL;
      mount(container, { assetBase: `${base}demos/pixel/` });
    }
  </script>
</div>

<style>
  .hero-custom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    padding-block: 1rem 2rem;
  }

  .hero-text {
    text-align: center;
    max-width: 60ch;
  }

  .hero-text h1 {
    font-size: clamp(var(--sl-text-3xl), calc(0.25rem + 5vw), var(--sl-text-6xl));
    line-height: var(--sl-line-height-headings);
    font-weight: 600;
    color: var(--sl-color-white);
  }

  .hero-demo {
    width: 100%;
    max-width: 1100px;
    aspect-ratio: 11 / 7;
    border-radius: 12px;
    overflow: hidden;
    box-shadow:
      0 4px 24px rgba(0, 0, 0, 0.25),
      0 0 0 1px rgba(0, 0, 0, 0.08);
    position: relative;
  }

  /* Adwaita-Window fills the demo container */
  .hero-demo :global(adw-window) {
    width: 100% !important;
    height: 100% !important;
    max-width: none;
    max-height: none;
    border-radius: 0;
    box-shadow: none;
    outline: none;
  }

  .demo-annotation {
    align-self: flex-end;
    margin-right: 2rem;
    margin-bottom: -1rem;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    color: var(--sl-color-gray-2);
    pointer-events: none;
    user-select: none;
  }

  .demo-annotation-text {
    font-family: 'Coming Soon', cursive;
    font-size: clamp(0.9rem, 1.8vw, 1.15rem);
    line-height: 1.35;
    text-align: right;
    transform: rotate(-3deg);
  }

  .demo-annotation-arrow {
    width: 80px;
    height: 60px;
    margin-right: 2.5rem;
  }

  @media (max-width: 600px) {
    .hero-demo {
      aspect-ratio: 4 / 3;
    }

    .demo-annotation {
      display: none;
    }
  }
</style>
