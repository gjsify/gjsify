---
// Custom Hero component — replaces Starlight's default Hero.
// VitePress-style layout: text block on the left (title, tagline, CTAs),
// large logo on the right. Stacks vertically on narrow viewports.
//
// CSS is declared `is:global` because Astro's scoped rules use `:where()`
// which has 0 specificity — Starlight's own `.sl-markdown-content h1` etc.
// would otherwise win and collapse the layout after hydration.
import ShowcaseSlideshow from './ShowcaseSlideshow.astro';
import LogoLight from '../assets/logo-light.svg?raw';
import LogoDark from '../assets/logo-dark.svg?raw';
---

<div class="hero-custom">
  <div class="hero-heading">
    <div class="hero-text">
      <h1 class="hero-title">GJSify</h1>
      <p class="hero-tagline">Node.js &amp; Web APIs,<br />running on GJS</p>
      <p class="hero-description">
        Bring the full TypeScript ecosystem to GJS &mdash; fs, net, http, fetch,
        WebSocket, Canvas2D, WebGL and more, all running natively on Linux.
      </p>
      <div class="hero-cta">
        <a class="hero-btn hero-btn-primary" href="/gjsify/getting-started/">Get Started</a>
        <a class="hero-btn hero-btn-minimal" href="https://github.com/gjsify/gjsify" target="_blank" rel="noopener">GitHub</a>
      </div>
    </div>

    <div class="hero-logo-wrapper" aria-hidden="true">
      <span class="hero-logo-light" set:html={LogoLight} />
      <span class="hero-logo-dark" set:html={LogoDark} />
    </div>
  </div>

  <ShowcaseSlideshow />
</div>

<style is:global>
  .hero-custom {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: clamp(4rem, 8vw, 8rem);
    padding-block: clamp(2rem, 5vw, 5rem) clamp(2rem, 5vw, 5rem);
    position: relative;
  }

  /* --- Heading section: two-column (text + logo) --- */
  .hero-custom .hero-heading {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 3rem;
    max-width: 1100px;
    width: 100%;
    margin-inline: auto;
  }

  .hero-custom .hero-text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    min-width: 0;
  }

  .hero-custom .hero-title {
    font-size: clamp(2.5rem, 5vw, 3.75rem);
    font-weight: 800;
    margin: 0;
    line-height: 1.05;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, var(--sl-color-accent-high) 0%, var(--sl-color-accent) 60%, #9141ac 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .hero-custom .hero-tagline {
    font-size: clamp(2.5rem, 5vw, 3.75rem);
    font-weight: 800;
    color: var(--sl-color-white);
    margin: 0;
    line-height: 1.05;
    letter-spacing: -0.02em;
  }

  .hero-custom .hero-description {
    font-size: clamp(0.95rem, 1.5vw, 1.125rem);
    color: var(--sl-color-gray-2);
    margin: 0.25rem 0 0;
    line-height: 1.55;
    max-width: 46ch;
  }

  /* --- Logo (right column) --- */
  .hero-custom .hero-logo-wrapper {
    width: clamp(160px, 20vw, 260px);
    aspect-ratio: 1;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    filter: drop-shadow(0 8px 32px rgba(53, 132, 228, 0.25));
  }

  .hero-custom .hero-logo-wrapper svg {
    width: 100%;
    height: 100%;
  }

  /* Theme-aware logo */
  .hero-custom .hero-logo-dark { display: none; }
  :root[data-theme='dark'] .hero-custom .hero-logo-light { display: none; }
  :root[data-theme='dark'] .hero-custom .hero-logo-dark { display: inline; }

  /* --- CTA buttons --- */
  .hero-custom .hero-cta {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;
    flex-wrap: wrap;
  }

  .hero-custom .hero-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.5rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: background 0.15s, box-shadow 0.15s, transform 0.15s;
  }

  .hero-custom .hero-btn-primary {
    background: var(--sl-color-accent);
    color: #fff;
  }

  .hero-custom .hero-btn-primary:hover {
    background: var(--sl-color-accent-high);
    box-shadow: 0 4px 16px rgba(53, 132, 228, 0.35);
    transform: translateY(-1px);
  }

  .hero-custom .hero-btn-minimal {
    background: transparent;
    color: var(--sl-color-white);
    border: 1px solid var(--sl-color-gray-5);
  }

  .hero-custom .hero-btn-minimal:hover {
    background: var(--sl-color-gray-6);
    border-color: var(--sl-color-gray-4);
  }

  /* --- Responsive --- */
  @media (max-width: 800px) {
    .hero-custom .hero-heading {
      grid-template-columns: 1fr;
      gap: 2rem;
      text-align: center;
    }

    .hero-custom .hero-text {
      align-items: center;
    }

    .hero-custom .hero-description {
      max-width: 50ch;
    }

    .hero-custom .hero-cta {
      justify-content: center;
    }

    /* Logo above the text on mobile */
    .hero-custom .hero-logo-wrapper {
      order: -1;
      width: clamp(120px, 30vw, 180px);
    }
  }
</style>
