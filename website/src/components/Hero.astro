---
// Custom Hero component — replaces Starlight's default Hero.
// Displays title, slogan, and CTA buttons, followed by the showcase slideshow.
import ShowcaseSlideshow from './ShowcaseSlideshow.astro';
import LogoLight from '../assets/logo-light.svg?raw';
import LogoDark from '../assets/logo-dark.svg?raw';
---

<div class="hero-custom">
  <div class="hero-heading">
    <div class="hero-logo">
      <span class="hero-logo-light" set:html={LogoLight} />
      <span class="hero-logo-dark" set:html={LogoDark} />
    </div>
    <h1 class="hero-title">GJSify</h1>
    <p class="hero-slogan">Run the entire TypeScript ecosystem natively on Linux</p>
    <div class="hero-cta">
      <a class="hero-btn hero-btn-primary" href="/gjsify/getting-started/">Get Started</a>
      <a class="hero-btn hero-btn-minimal" href="https://github.com/gjsify/gjsify" target="_blank" rel="noopener">GitHub</a>
    </div>
  </div>

  <ShowcaseSlideshow />
</div>

<style>
  .hero-custom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.5rem;
    padding-block: 2rem 2rem;
    position: relative;
  }

  /* --- Heading section --- */
  .hero-heading {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    text-align: center;
    max-width: 700px;
  }

  .hero-logo {
    width: 80px;
    height: 80px;
    margin-bottom: 0.25rem;
  }

  .hero-logo :global(svg) {
    width: 100%;
    height: 100%;
  }

  /* Theme-aware logo */
  .hero-logo-dark { display: none; }
  :root[data-theme='dark'] .hero-logo-light { display: none; }
  :root[data-theme='dark'] .hero-logo-dark { display: inline; }

  .hero-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    margin: 0;
    line-height: 1.1;
  }

  .hero-slogan {
    font-size: clamp(1rem, 2.5vw, 1.35rem);
    color: var(--sl-color-gray-2);
    margin: 0;
    line-height: 1.4;
  }

  /* --- CTA buttons --- */
  .hero-cta {
    display: flex;
    gap: 1rem;
    margin-top: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.4rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: background 0.15s, box-shadow 0.15s;
  }

  .hero-btn-primary {
    background: var(--sl-color-accent);
    color: #fff;
  }

  .hero-btn-primary:hover {
    background: var(--sl-color-accent-high);
    box-shadow: 0 2px 8px rgba(53, 132, 228, 0.3);
  }

  .hero-btn-minimal {
    background: transparent;
    color: var(--sl-color-gray-2);
    border: 1px solid var(--sl-color-gray-5);
  }

  .hero-btn-minimal:hover {
    background: var(--sl-color-gray-6);
  }

  /* --- Responsive --- */
  @media (max-width: 600px) {
    .hero-logo {
      width: 60px;
      height: 60px;
    }
  }
</style>
