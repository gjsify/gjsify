{
  "name": "@gjsify/example-dom-webgl-tutorial-07",
  "version": "0.1.5",
  "description": "",
  "main": "dist/gjs.js",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "clear": "rm -rf dist tsconfig.tsbuildinfo",
    "check": "tsc --noEmit --skipLibCheck --strictNullChecks false --noImplicitAny false",
    "start": "gjsify run dist/gjs.js",
    "start:browser": "http-server dist",
    "build": "yarn build:gjs && yarn build:browser && yarn build:assets",
    "build:gjs": "gjsify build src/gjs/gjs.ts --app gjs --outfile dist/gjs.js",
    "build:assets": "cp -f src/browser/index.html dist/index.html && cp -f src/browser/webgl.css dist/webgl.css && cp -f src/cubetexture.png dist/cubetexture.png",
    "build:browser": "gjsify build src/browser/browser.ts --app browser --outfile dist/browser.js"
  },
  "dependencies": {
    "@gjsify/webgl": "workspace:^"
  },
  "devDependencies": {
    "@girs/gio-2.0": "^2.88.0-4.0.0-rc.1",
    "@girs/gjs": "^4.0.0-rc.1",
    "@girs/gtk-4.0": "^4.23.0-4.0.0-rc.1",
    "@gjsify/cli": "workspace:^",
    "@types/gl-matrix": "^3.2.0",
    "@types/node": "^25.5.2",
    "gl-matrix": "^3.4.4",
    "http-server": "^14.1.1",
    "typescript": "^6.0.2"
  },
  "author": "Pascal Garber <pascal@artandcode.studio>",
  "license": "MIT"
}
