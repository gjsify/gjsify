{
  "name": "@gjsify/example-dom-canvas2d-text",
  "version": "0.1.2",
  "description": "Canvas 2D textBaseline visual comparison demo — GJS (Cairo/PangoCairo) vs browser",
  "main": "dist/gjs.js",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "clear": "rm -rf dist tsconfig.tsbuildinfo",
    "check": "tsc --noEmit --skipLibCheck --strictNullChecks false --noImplicitAny false",
    "start": "gjsify run dist/gjs.js",
    "start:browser": "http-server dist",
    "build": "yarn build:gjs && yarn build:browser && yarn build:assets",
    "build:gjs": "gjsify build src/gjs/gjs.ts --app gjs --outfile dist/gjs.js",
    "build:browser": "gjsify build src/browser/browser.ts --app browser --outfile dist/browser.js",
    "build:assets": "cp -f src/browser/index.html dist/index.html"
  },
  "devDependencies": {
    "@girs/gio-2.0": "^2.88.0-4.0.0-beta.43",
    "@girs/gjs": "^4.0.0-beta.43",
    "@girs/gtk-4.0": "^4.22.1-4.0.0-beta.43",
    "@gjsify/canvas2d": "workspace:^",
    "@gjsify/cli": "workspace:^",
    "@types/node": "^25.5.0",
    "http-server": "^14.1.1",
    "typescript": "^6.0.2"
  },
  "author": "Pascal Garber <pascal@artandcode.studio>",
  "license": "MIT"
}
