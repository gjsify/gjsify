{
  "name": "@gjsify/example-dom-webtorrent-seed",
  "description": "WebTorrent local seed + download demo — tests WebRTC data channels via P2P torrent transfer for GJS and browser",
  "main": "dist/gjs.js",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "clear": "rm -rf dist tsconfig.tsbuildinfo",
    "check": "tsc --noEmit",
    "start": "yarn start:gjs",
    "start:gjs": "gjsify run dist/gjs.js",
    "start:browser": "http-server dist -o -c-1",
    "build": "yarn build:gjs && yarn build:browser && yarn build:assets",
    "build:gjs": "gjsify build src/gjs/gjs.ts --app gjs --outfile dist/gjs.js --globals auto,RTCPeerConnection,RTCSessionDescription,RTCIceCandidate,WebSocket,fetch",
    "build:browser": "gjsify build src/browser/browser.ts --app gjs --outfile dist/browser.js --globals none",
    "build:assets": "cp -f src/browser/index.html dist/index.html"
  },
  "devDependencies": {
    "@girs/gjs": "^4.0.0-rc.3",
    "@girs/glib-2.0": "^2.88.0-4.0.0-rc.3",
    "@gjsify/cli": "workspace:^",
    "@gjsify/node-globals": "workspace:^",
    "@gjsify/runtime": "workspace:^",
    "@gjsify/webrtc": "workspace:^",
    "@gjsify/websocket": "workspace:^",
    "@types/node": "^25.6.0",
    "http-server": "^14.1.1",
    "typescript": "^6.0.2",
    "webtorrent": "^2.5.18"
  },
  "private": true
}
