{
  "name": "@gjsify/example-node-cli-node-events",
  "description": "",
  "main": "dist/index.gjs.js",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "clear": "rm -rf dist tsconfig.tsbuildinfo",
    "check": "tsc --noEmit",
    "start": "yarn start:node && yarn start:gjs",
    "start:gjs": "gjsify run dist/index.gjs.js",
    "start:node": "node dist/index.node.cjs",
    "build": "yarn build:gjs && yarn build:node",
    "build:gjs": "gjsify build src/index.ts --app gjs --outfile dist/index.gjs.js",
    "build:node": "gjsify build src/index.ts --app node --outfile dist/index.node.cjs",
    "test": "yarn start"
  },
  "devDependencies": {
    "@gjsify/cli": "workspace:^",
    "@gjsify/events": "workspace:^",
    "@gjsify/node-globals": "workspace:^",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  },
  "author": "Pascal Garber <pascal@artandcode.studio>",
  "license": "MIT",
  "private": true,
  "version": "0.3.4"
}
