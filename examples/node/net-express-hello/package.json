{
  "name": "@gjsify/example-node-net-express-hello",
  "description": "Simple Express.js HTTP server example for Node.js and GJS",
  "main": "dist/index.gjs.js",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "clear": "rm -rf dist tsconfig.tsbuildinfo",
    "check": "tsc --noEmit",
    "start": "yarn start:gjs",
    "start:gjs": "gjsify run dist/index.gjs.js",
    "start:node": "node dist/index.node.mjs",
    "build": "yarn build:gjs && yarn build:node",
    "build:gjs": "gjsify build src/index.ts --app gjs --outfile dist/index.gjs.js",
    "build:node": "gjsify build src/index.ts --app node --outfile dist/index.node.mjs",
    "build:test:gjs": "gjsify build src/test.mts --app gjs --outfile test.gjs.mjs",
    "build:test:node": "gjsify build src/test.mts --app node --outfile test.node.mjs",
    "build:test": "yarn build:test:gjs && yarn build:test:node",
    "test": "yarn build && yarn build:test:node && yarn test:node",
    "test:node": "node test.node.mjs",
    "test:gjs": "gjsify run test.gjs.mjs"
  },
  "devDependencies": {
    "@gjsify/cli": "workspace:^",
    "@gjsify/node-globals": "workspace:^",
    "@gjsify/runtime": "workspace:^",
    "@gjsify/unit": "workspace:^",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "express": "^5.2.1",
    "typescript": "^6.0.3"
  },
  "author": "Pascal Garber <pascal@artandcode.studio>",
  "license": "MIT",
  "private": true,
  "version": "0.3.2"
}
