{
  "name": "@gjsify/example-node-gtk-http-dashboard",
  "description": "GTK4 dashboard with embedded HTTP server (GJS only)",
  "main": "dist/index.gjs.js",
  "type": "module",
  "scripts": {
    "clear": "rm -rf dist tsconfig.tsbuildinfo",
    "check": "tsc --noEmit --skipLibCheck",
    "start": "gjs -m dist/index.gjs.js",
    "build": "yarn build:gjs",
    "build:gjs": "gjsify build src/index.ts --app gjs --globals node,web --outfile dist/index.gjs.js"
  },
  "devDependencies": {
    "@girs/gio-2.0": "^2.88.0-4.0.0-rc.1",
    "@girs/gjs": "^4.0.0-rc.1",
    "@girs/glib-2.0": "^2.88.0-4.0.0-rc.1",
    "@girs/gtk-4.0": "^4.23.0-4.0.0-rc.1",
    "@gjsify/cli": "workspace:^",
    "@gjsify/node-globals": "workspace:^",
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2"
  },
  "private": true,
  "version": "0.1.8"
}
