{
  "name": "@gjsify/example-node-cli-gio-cat",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "type": "module",
  "scripts": {
    "clear": "rm -rf dist tsconfig.tsbuildinfo",
    "check": "tsc --noEmit",
    "start": "gjs -m dist/index.js",
    "build": "yarn build:gjs",
    "build:gjs": "gjsify build src/index.ts --app gjs --outfile dist/index.js",
    "test": "yarn build && rm -f /tmp/gio-cat-example.txt && echo ok > /tmp/gio-cat-example.txt && gjs -m dist/index.js /tmp/gio-cat-example.txt"
  },
  "devDependencies": {
    "@girs/gio-2.0": "^2.88.0-4.0.0-rc.1",
    "@girs/gjs": "^4.0.0-rc.1",
    "@gjsify/cli": "workspace:^",
    "typescript": "^6.0.2"
  },
  "private": true,
  "version": "0.1.8"
}
