{
  "name": "@gjsify/example-gtk-webgl-tutorial-07",
  "private": true,
  "version": "0.0.4",
  "description": "",
  "main": "dist/index.gjs.js",
  "type": "module",
  "scripts": {
    "clear": "rm -rf dist tsconfig.tsbuildinfo",
    "check": "tsc --noEmit --skipLibCheck --strictNullChecks false --noImplicitAny false",
    "start": "LD_LIBRARY_PATH=../../../packages/dom/webgl/build GI_TYPELIB_PATH=../../../packages/dom/webgl/build gjs -m dist/gjs.js",
    "start:browser": "http-server dist",
    "build": "yarn build:gjs && yarn build:browser && yarn build:assets",
    "build:gjs": "gjsify build src/gjs.ts --app gjs --outfile dist/gjs.js",
    "build:assets": "cp -f src/index.html dist/index.html && cp -f src/webgl.css dist/webgl.css && cp -f src/cubetexture.png dist/cubetexture.png",
    "build:browser": "gjsify build src/browser.ts --app browser --outfile dist/browser.js"
  },
  "engines": {
    "node": "16",
    "gjs": "1.72.x"
  },
  "author": "Pascal Garber <pascal@artandcode.studio>",
  "license": "MIT",
  "devDependencies": {
    "@gjsify/cli": "workspace:^",
    "@types/gl-matrix": "^3.2.0",
    "@types/node": "^25.5.0",
    "http-server": "^14.1.1",
    "open-cli": "^9.0.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@girs/gio-2.0": "^2.88.0-4.0.0-beta.42",
    "@girs/gjs": "^4.0.0-beta.42",
    "@girs/gtk-4.0": "^4.22.1-4.0.0-beta.42",
    "@gjsify/webgl": "workspace:^",
    "gl-matrix": "^3.4.4"
  }
}
