{
  "name": "@gjsify/example-gtk-webgl-tutorial-05",
  "private": true,
  "version": "0.0.4",
  "description": "",
  "main": "dist/index.gjs.js",
  "type": "module",
  "scripts": {
    "clear": "rm -rf dist tsconfig.tsbuildinfo",
    "check": "tsc --noEmit --skipLibCheck --strictNullChecks false --noImplicitAny false",
    "start": "gjsify run dist/gjs.js",
    "start:browser": "open-cli index.html",
    "build": "yarn build:gjs && yarn build:browser",
    "build:gjs": "gjsify build src/gjs.ts --app gjs --outfile dist/gjs.js",
    "build:browser": "gjsify build src/browser.ts --app browser --outfile dist/browser.js"
  },
  "engines": {
    "node": "16",
    "gjs": "1.72.x"
  },
  "author": "Pascal Garber <pascal@artandcode.studio>",
  "license": "MIT",
  "devDependencies": {
    "@gjsify/cli": "workspace:^",
    "@types/gl-matrix": "^3.2.0",
    "@types/node": "^25.5.0",
    "open-cli": "^9.0.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@girs/gio-2.0": "^2.88.0-4.0.0-beta.42",
    "@girs/gjs": "^4.0.0-beta.42",
    "@girs/gtk-4.0": "^4.22.1-4.0.0-beta.42",
    "@gjsify/webgl": "workspace:^",
    "gl-matrix": "^3.4.4"
  }
}
