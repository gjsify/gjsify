{
  "name": "@gjsify/example-net-koa-blog",
  "version": "0.0.4",
  "private": true,
  "type": "module",
  "main": "dist/index.gjs.js",
  "description": "Koa.js blog example with EJS templates for Node.js and GJS",
  "scripts": {
    "clear": "rm -rf dist tsconfig.tsbuildinfo",
    "check": "tsc --noEmit",
    "start": "yarn start:node",
    "start:gjs": "gjs -m dist/index.gjs.js",
    "start:node": "node dist/index.node.mjs",
    "build": "yarn build:gjs && yarn build:node && yarn build:views",
    "build:gjs": "gjsify build src/index.ts --app gjs --outfile dist/index.gjs.js",
    "build:node": "gjsify build src/index.ts --app node --outfile dist/index.node.mjs",
    "build:views": "cp -r src/views dist/views",
    "test": "yarn start"
  },
  "dependencies": {
    "@gjsify/node-globals": "workspace:^",
    "@gjsify/runtime": "workspace:^",
    "@koa/router": "^15.4.0",
    "ejs": "^5.0.1",
    "koa": "^3.1.2",
    "koa-bodyparser": "^4.4.1"
  },
  "devDependencies": {
    "@gjsify/cli": "workspace:^",
    "@types/ejs": "^3.1.5",
    "@types/koa": "^3.0.2",
    "@types/koa-bodyparser": "^4.3.13",
    "@types/koa__router": "^12.0.5",
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=16",
    "gjs": ">=1.72.x"
  }
}
