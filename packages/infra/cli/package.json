{
    "name": "@gjsify/cli",
    "version": "0.4.14",
    "description": "CLI for Gjsify",
    "type": "module",
    "main": "lib/index.js",
    "module": "lib/index.js",
    "types": "lib/index.d.ts",
    "bin": {
        "gjsify": "./lib/index.js"
    },
    "gjsify": {
        "bin": {
            "gjsify": "./dist/cli.gjs.mjs"
        }
    },
    "files": [
        "lib",
        "dist/cli.gjs.mjs",
        "showcases.json"
    ],
    "scripts": {
        "clear": "rm -rf lib dist tsconfig.tsbuildinfo || exit 0",
        "check": "tsc --noEmit",
        "start": "node lib/index.js",
        "build": "tsc && mkdir -p lib/templates/flatpak && cp -L src/templates/install.mjs.tmpl lib/templates/install.mjs.tmpl && cp src/templates/flatpak/*.tmpl lib/templates/flatpak/ && cp src/templates/biome.json.tmpl lib/templates/biome.json.tmpl && gjsify run chmod",
        "build:gjs-bundle": "node lib/index.js build src/index.ts --app gjs --outfile dist/cli.gjs.mjs --shebang",
        "chmod": "chmod +x ./lib/index.js",
        "build:test:node": "node lib/index.js build src/test.mts --app node --outfile dist/test.node.mjs",
        "test:node": "node dist/test.node.mjs",
        "test": "gjsify run build:test:node && gjsify run test:node"
    },
    "keywords": [
        "gjs",
        "node",
        "gjsify",
        "cli"
    ],
    "dependencies": {
        "@gjsify/buffer": "workspace:^",
        "@gjsify/create-app": "workspace:^",
        "@gjsify/node-globals": "workspace:^",
        "@gjsify/node-polyfills": "workspace:^",
        "@gjsify/npm-registry": "workspace:^",
        "@gjsify/resolve-npm": "workspace:^",
        "@gjsify/rolldown-plugin-gjsify": "workspace:^",
        "@gjsify/rolldown-plugin-pnp": "workspace:^",
        "@gjsify/semver": "workspace:^",
        "@gjsify/tar": "workspace:^",
        "@gjsify/web-polyfills": "workspace:^",
        "@gjsify/workspace": "workspace:^",
        "cosmiconfig": "^9.0.1",
        "get-tsconfig": "^4.14.0",
        "pkg-types": "^2.3.1",
        "rolldown": "^1.0.0",
        "yargs": "^18.0.0"
    },
    "devDependencies": {
        "@gjsify/unit": "workspace:^",
        "@types/yargs": "^17.0.35",
        "typescript": "^6.0.3"
    },
    "peerDependencies": {
        "@gjsify/rolldown-native": "workspace:^"
    },
    "peerDependenciesMeta": {
        "@gjsify/rolldown-native": {
            "optional": true
        }
    }
}
