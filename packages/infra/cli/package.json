{
    "name": "@gjsify/cli",
    "version": "0.1.0",
    "description": "CLI for Gjsify",
    "type": "module",
    "main": "lib/index.js",
    "module": "lib/index.js",
    "types": "lib/index.d.ts",
    "bin": {
        "gjsify": "./lib/index.js"
    },
    "scripts": {
        "clear": "rm -rf lib tsconfig.tsbuildinfo || exit 0",
        "check": "tsc --noEmit",
        "start": "node lib/index.js",
        "build": "tsc && yarn chmod",
        "chmod": "chmod +x ./lib/index.js"
    },
    "keywords": [
        "gjs",
        "node",
        "gjsify",
        "cli"
    ],
    "dependencies": {
        "@gjsify/esbuild-plugin-gjsify": "workspace:^",
        "cosmiconfig": "^9.0.1",
        "esbuild": "^0.27.4",
        "get-tsconfig": "^4.13.7",
        "pkg-types": "^2.3.0",
        "yargs": "^18.0.0"
    },
    "devDependencies": {
        "@types/yargs": "^17.0.35",
        "typescript": "^6.0.2"
    }
}
