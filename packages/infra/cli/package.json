{
    "name": "@gjsify/cli",
    "version": "0.3.9",
    "description": "CLI for Gjsify",
    "type": "module",
    "main": "lib/index.js",
    "module": "lib/index.js",
    "types": "lib/index.d.ts",
    "bin": {
        "gjsify": "./lib/index.js"
    },
    "scripts": {
        "clear": "rm -rf lib tsconfig.tsbuildinfo || exit 0",
        "check": "tsc --noEmit",
        "start": "node lib/index.js",
        "build": "tsc && yarn chmod",
        "chmod": "chmod +x ./lib/index.js"
    },
    "keywords": [
        "gjs",
        "node",
        "gjsify",
        "cli"
    ],
    "dependencies": {
        "@gjsify/create-app": "workspace:^",
        "@gjsify/esbuild-plugin-gjsify": "workspace:^",
        "@gjsify/node-polyfills": "workspace:^",
        "@gjsify/npm-registry": "workspace:^",
        "@gjsify/resolve-npm": "workspace:^",
        "@gjsify/semver": "workspace:^",
        "@gjsify/tar": "workspace:^",
        "@gjsify/web-polyfills": "workspace:^",
        "@yarnpkg/esbuild-plugin-pnp": "^3.0.0-rc.15",
        "cosmiconfig": "^9.0.1",
        "esbuild": "^0.28.0",
        "get-tsconfig": "^4.14.0",
        "pkg-types": "^2.3.1",
        "yargs": "^18.0.0"
    },
    "devDependencies": {
        "@types/yargs": "^17.0.35",
        "typescript": "^6.0.3"
    }
}
