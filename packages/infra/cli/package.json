{
    "name": "@gjsify/cli",
    "version": "0.1.6",
    "description": "CLI for Gjsify",
    "type": "module",
    "main": "lib/index.js",
    "module": "lib/index.js",
    "types": "lib/index.d.ts",
    "bin": {
        "gjsify": "./lib/index.js"
    },
    "scripts": {
        "clear": "rm -rf lib tsconfig.tsbuildinfo || exit 0",
        "check": "tsc --noEmit",
        "start": "node lib/index.js",
        "build": "tsc && yarn chmod",
        "chmod": "chmod +x ./lib/index.js"
    },
    "keywords": [
        "gjs",
        "node",
        "gjsify",
        "cli"
    ],
    "dependencies": {
        "@gjsify/esbuild-plugin-gjsify": "workspace:^",
