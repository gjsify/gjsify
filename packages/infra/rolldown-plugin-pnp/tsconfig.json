{
    "compilerOptions": {
        "rootDir": "src",
        "outDir": "lib",
        "declaration": true,
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "types": ["node"]
    },
    "include": ["src/**/*"]
}
