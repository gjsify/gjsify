{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ESNext",
    "rootDir": "src",
    "outDir": "dist",
    "types": [
      "node"
    ],
    "lib": [
      "ESNext",
      "DOM"
    ],
    "declarationDir": "dist/types",
    "declaration": true,
    "emitDeclarationOnly": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "strict": false
  },
  "include": [
    "src/lodash.d.ts"
  ],
  "files": [
    "src/index.ts",
    "src/globals.ts"
  ]
}
