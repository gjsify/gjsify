{
    "name": "@gjsify/create-app",
    "version": "0.1.8",
    "description": "Create a new Gjsify project",
    "type": "module",
    "main": "lib/create.js",
    "types": "lib/create.d.ts",
    "exports": {
        ".": {
            "types": "./lib/create.d.ts",
            "import": "./lib/create.js"
        },
        "./package.json": "./package.json"
    },
    "bin": "./lib/index.js",
    "scripts": {
        "clear": "rm -rf lib tsconfig.tsbuildinfo || exit 0",
        "check": "tsc --noEmit",
        "build": "node scripts/process-template.mjs && tsc && chmod +x ./lib/index.js",
        "test": "echo 'nothing to do'"
    },
    "keywords": [
        "gjs",
        "gjsify",
        "create",
        "scaffold",
        "gnome"
    ],
    "files": [
        "lib",
        "templates"
    ],
    "dependencies": {
        "yargs": "^18.0.0"
    },
    "devDependencies": {
        "@types/node": "^25.5.2",
        "@types/yargs": "^17.0.35",
        "typescript": "^6.0.2"
    }
}
