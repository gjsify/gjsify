{
    "compilerOptions": {
        "outDir": "lib",
        "declarationDir": "lib/types",
        "rootDir": "src",
        "tsBuildInfoFile": "tmp/.tsbuildinfo",
        "target": "es2020",
        "declaration": true,
        "emitDeclarationOnly": true,
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "esModuleInterop": true,
        "experimentalDecorators": true,
        "resolveJsonModule": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "removeComments": false,
        "preserveConstEnums": true,
        "sourceMap": true,
        "skipLibCheck": true,
        "composite": true,
        "incremental": true,
        "types": [
            "node"
        ],
        "lib": [
            "es2015",
            "es2016",
            "es2017",
            "DOM"
        ],
        "strict": false
    },
    "include": [
        "src",
        "../../../node_modules/@girs/gdk-4.0/gdk-4.0-ambient.d.ts",
        "../../../node_modules/@girs/gdkpixbuf-2.0/gdkpixbuf-2.0-ambient.d.ts",
        "../../../node_modules/@girs/pango-1.0/pango-1.0-ambient.d.ts",
        "../../../node_modules/@girs/pangocairo-1.0/pangocairo-1.0-ambient.d.ts",
        "../../../node_modules/@girs/glib-2.0/glib-2.0-ambient.d.ts",
        "../../../node_modules/@girs/gobject-2.0/gobject-2.0-ambient.d.ts"
    ],
    "exclude": [
        "src/test.mts"
    ]
}
