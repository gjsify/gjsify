{
    "name": "@gjsify/webgl",
    "version": "0.0.4",
    "description": "WebGL module for Gjs",
    "module": "lib/esm/index.js",
    "types": "lib/types/index.d.ts",
    "type": "module",
    "exports": {
        ".": {
            "types": "./lib/types/index.d.ts",
            "default": "./lib/esm/index.js"
        }
    },
    "files": [
        "lib",
        "prebuilds"
    ],
    "gjsify": {
        "prebuilds": "prebuilds"
    },
    "scripts": {
        "clear": "rm -rf lib tmp build test.gjs.mjs tsconfig.tsbuildinfo tsconfig.types.tsbuildinfo || exit 0",
        "check": "tsc --noEmit",
        "init:meson": "meson setup build .",
        "init:meson:wipe": "yarn init:meson --wipe",
        "build": "yarn build:meson && yarn build:gjsify && yarn build:types",
        "build:gjsify": "gjsify build --library 'src/ts/**/*.{ts,js}'",
        "build:meson": "yarn init:meson && meson compile -C build",
        "build:types": "tsc",
        "build:prebuilds": "yarn build:meson && mkdir -p prebuilds/linux-x86_64 && cp build/libgwebgl.so build/Gwebgl-0.1.typelib prebuilds/linux-x86_64/",
        "build:test": "gjsify build src/ts/test.ts --app gjs --outfile test.gjs.js",
        "test": "yarn build:gjsify && yarn build:test && yarn test:gjs",
        "test:gjs": "gjsify run test.gjs.js"
    },
    "keywords": [
        "gjs",
        "WebGL"
    ],
    "devDependencies": {
        "@gjsify/cli": "workspace:^",
        "@gjsify/unit": "workspace:^",
        "@types/node": "^25.5.0",
        "typescript": "^6.0.2"
    },
    "dependencies": {
        "@girs/gio-2.0": "^2.88.0-4.0.0-beta.42",
        "@girs/gjs": "^4.0.0-beta.42",
        "@girs/gtk-4.0": "4.22.1-4.0.0-beta.42",
        "@girs/gwebgl-0.1": "workspace:^",
        "@gjsify/dom-elements": "workspace:^",
        "@gjsify/gtk-dom-event-bridge": "workspace:^",
        "@gjsify/utils": "workspace:^",
        "@types/bit-twiddle": "^1.0.3",
        "bit-twiddle": "^1.0.2",
        "glsl-tokenizer": "^2.1.5"
    }
}
