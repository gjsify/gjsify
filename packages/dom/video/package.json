{
    "name": "@gjsify/video",
    "version": "0.1.15",
    "description": "VideoBridge — GTK container for HTMLVideoElement backed by GStreamer gtk4paintablesink",
    "type": "module",
    "module": "lib/esm/index.js",
    "types": "lib/types/index.d.ts",
    "exports": {
        ".": {
            "types": "./lib/types/index.d.ts",
            "default": "./lib/esm/index.js"
        }
    },
    "scripts": {
        "clear": "rm -rf lib tmp tsconfig.tsbuildinfo || exit 0",
        "check": "tsc --noEmit",
        "build": "yarn build:gjsify && yarn build:types",
        "build:gjsify": "gjsify build --library 'src/**/*.{ts,js}' --exclude 'src/**/*.spec.{mts,ts}' 'src/test.{mts,ts}'",
        "build:types": "tsc"
    },
    "keywords": [
        "gjs",
        "gtk",
        "video",
        "gstreamer",
        "bridge"
    ],
    "dependencies": {
        "@girs/gdk-4.0": "^4.0.0-4.0.0-rc.3",
        "@girs/gjs": "^4.0.0-rc.3",
        "@girs/glib-2.0": "^2.88.0-4.0.0-rc.3",
        "@girs/gobject-2.0": "^2.88.0-4.0.0-rc.3",
        "@girs/gst-1.0": "^1.28.1-4.0.0-rc.3",
        "@girs/gtk-4.0": "^4.23.0-4.0.0-rc.3",
        "@gjsify/bridge-types": "workspace:^",
        "@gjsify/dom-elements": "workspace:^",
        "@gjsify/dom-events": "workspace:^",
        "@gjsify/event-bridge": "workspace:^"
    },
    "devDependencies": {
        "@gjsify/cli": "workspace:^",
        "@types/node": "^25.6.0",
        "typescript": "^6.0.2"
    }
}
