{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "lib",
    "types": [
      "node"
    ],
    "lib": [
      "ESNext"
    ],
    "declarationDir": "lib/types",
    "declaration": true,
    "emitDeclarationOnly": true,
    "esModuleInterop": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node10",
    "ignoreDeprecations": "6.0",
    "strict": false
  },
  "files": [
    "src/index.ts"
  ],
  "include": [
    "@girs/gjs"
  ],
  "exclude": [
    "src/test.ts",
    "src/test.mts",
    "src/**/*.spec.ts",
    "src/**/*.spec.mts"
  ]
}
