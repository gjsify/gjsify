{
    "name": "@gjsify/constants",
    "version": "0.4.0",
    "description": "Node.js constants module for Gjs (deprecated, re-exports from os/fs/crypto)",
    "type": "module",
    "module": "lib/esm/index.js",
    "types": "lib/types/index.d.ts",
    "exports": {
        ".": {
            "types": "./lib/types/index.d.ts",
            "default": "./lib/esm/index.js"
        }
    },
    "scripts": {
        "clear": "rm -rf lib tsconfig.tsbuildinfo tsconfig.types.tsbuildinfo test.gjs.mjs test.node.mjs || exit 0",
        "check": "tsc --noEmit",
        "build": "npm run build:gjsify && npm run build:types",
        "build:gjsify": "gjsify build --library 'src/**/*.{ts,js}' --exclude 'src/**/*.spec.{mts,ts}' 'src/test.{mts,ts}'",
        "build:types": "tsc",
        "build:test": "npm run build:test:gjs && npm run build:test:node",
        "build:test:gjs": "gjsify build src/test.mts --app gjs --outfile test.gjs.mjs",
        "build:test:node": "gjsify build src/test.mts --app node --outfile test.node.mjs",
        "test": "npm run build:gjsify && npm run build:test && npm run test:node && npm run test:gjs",
        "test:gjs": "gjsify run test.gjs.mjs",
        "test:node": "node test.node.mjs"
    },
    "keywords": [
        "gjs",
        "node",
        "constants"
    ],
    "dependencies": {
        "@gjsify/crypto": "workspace:^",
        "@gjsify/fs": "workspace:^",
        "@gjsify/os": "workspace:^"
    },
    "devDependencies": {
        "@gjsify/cli": "workspace:^",
        "@gjsify/unit": "workspace:^",
        "@types/node": "^25.6.2",
        "typescript": "^6.0.3"
    }
}
