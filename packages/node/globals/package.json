{
    "name": "@gjsify/node-globals",
    "version": "0.1.8",
    "description": "Node.js globals module for Gjs",
    "keywords": [
        "gjs",
        "node",
        "globals"
    ],
    "author": "Pascal Garber",
    "module": "lib/esm/index.js",
    "types": "lib/types/index.d.ts",
    "type": "module",
    "exports": {
        ".": {
            "types": "./lib/types/index.d.ts",
            "default": "./lib/esm/index.js"
        },
        "./register": {
            "types": "./lib/types/register.d.ts",
            "default": "./lib/esm/register.js"
        },
        "./register/process": {
            "default": "./lib/esm/register/process.js"
        },
        "./register/buffer": {
            "default": "./lib/esm/register/buffer.js"
        },
        "./register/timers": {
            "default": "./lib/esm/register/timers.js"
        },
        "./register/encoding": {
            "default": "./lib/esm/register/encoding.js"
        },
        "./register/url": {
            "default": "./lib/esm/register/url.js"
        },
        "./register/structured-clone": {
            "default": "./lib/esm/register/structured-clone.js"
        },
        "./register/microtask": {
            "default": "./lib/esm/register/microtask.js"
        }
    },
    "sideEffects": [
        "./lib/esm/register.js",
        "./lib/esm/register/*.js"
    ],
    "scripts": {
        "clear": "rm -rf lib tsconfig.tsbuildinfo tsconfig.types.tsbuildinfo test.gjs.mjs test.node.mjs || exit 0",
        "check": "tsc --noEmit",
        "build": "yarn build:gjsify && yarn build:types",
        "build:gjsify": "gjsify build --library 'src/**/*.{ts,js}' --exclude 'src/**/*.spec.{mts,ts}' 'src/test.{mts,ts}'",
        "build:types": "tsc",
        "build:test": "yarn build:test:gjs && yarn build:test:node",
        "build:test:gjs": "gjsify build src/test.mts --app gjs --outfile test.gjs.mjs",
        "build:test:node": "gjsify build src/test.mts --app node --outfile test.node.mjs",
        "test": "yarn build:gjsify && yarn build:test && yarn test:node && yarn test:gjs",
        "test:gjs": "gjs -m test.gjs.mjs",
        "test:node": "node test.node.mjs"
    },
    "dependencies": {
        "@girs/glib-2.0": "^2.88.0-4.0.0-rc.1",
        "@gjsify/buffer": "workspace:^",
        "@gjsify/process": "workspace:^",
        "@gjsify/url": "workspace:^",
        "@gjsify/utils": "workspace:^"
    },
    "devDependencies": {
        "@gjsify/cli": "workspace:^",
        "@gjsify/unit": "workspace:^",
        "@types/node": "^25.5.2",
        "typescript": "^6.0.2"
    }
}
