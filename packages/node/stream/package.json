{
    "name": "@gjsify/stream",
    "version": "0.3.2",
    "description": "Node.js stream module for Gjs",
    "type": "module",
    "module": "lib/esm/index.js",
    "types": "lib/types/index.d.ts",
    "exports": {
        ".": {
            "types": "./lib/types/index.d.ts",
            "require": "./cjs-compat.cjs",
            "default": "./lib/esm/index.js"
        },
        "./consumers": {
            "types": "./lib/types/consumers/index.d.ts",
            "default": "./lib/esm/consumers/index.js"
        },
        "./promises": {
            "types": "./lib/types/promises/index.d.ts",
            "default": "./lib/esm/promises/index.js"
        },
        "./web": {
            "types": "./lib/types/web/index.d.ts",
            "default": "./lib/esm/web/index.js"
        }
    },
    "scripts": {
        "clear": "rm -rf lib tsconfig.tsbuildinfo tsconfig.types.tsbuildinfo test.gjs.mjs test.node.mjs || exit 0",
        "check": "tsc --noEmit",
        "build": "yarn build:gjsify && yarn build:types",
        "build:gjsify": "gjsify build --library 'src/**/*.{ts,js}' --exclude 'src/**/*.spec.{mts,ts}' 'src/test.{mts,ts}'",
        "build:types": "tsc",
        "build:test": "yarn build:test:gjs && yarn build:test:node",
        "build:test:gjs": "gjsify build src/test.mts --app gjs --outfile test.gjs.mjs",
        "build:test:node": "gjsify build src/test.mts --app node --outfile test.node.mjs",
        "test": "yarn build:gjsify && yarn build:test && yarn test:node && yarn test:gjs",
        "test:gjs": "gjsify run test.gjs.mjs",
        "test:node": "node test.node.mjs"
    },
    "keywords": [
        "gjs",
        "node",
        "stream"
    ],
    "devDependencies": {
        "@gjsify/cli": "workspace:^",
        "@gjsify/unit": "workspace:^",
        "@types/node": "^25.6.0",
        "typescript": "^6.0.3"
    },
    "dependencies": {
        "@gjsify/events": "workspace:^",
        "@gjsify/utils": "workspace:^",
        "@gjsify/web-streams": "workspace:^"
    }
}
