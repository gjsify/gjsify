{
    "name": "@gjsify/adw-app",
    "version": "0.1.15",
    "description": "Adwaita application bootstrap helper for GJS — composes Adw.Application + ApplicationWindow + ToolbarView + HeaderBar into a single runAdwApp({ applicationId, title, build }) call",
    "type": "module",
    "module": "lib/esm/index.js",
    "types": "lib/types/index.d.ts",
    "exports": {
        ".": {
            "types": "./lib/types/index.d.ts",
            "default": "./lib/esm/index.js"
        }
    },
    "scripts": {
        "clear": "rm -rf lib tmp tsconfig.tsbuildinfo || exit 0",
        "check": "tsc --noEmit",
        "build": "yarn build:gjsify && yarn build:types",
        "build:gjsify": "gjsify build --library 'src/**/*.{ts,js}' --exclude 'src/**/*.spec.{mts,ts}' 'src/test.{mts,ts}'",
        "build:types": "tsc"
    },
    "keywords": [
        "gjs",
        "gtk",
        "adwaita",
        "framework",
        "app"
    ],
    "dependencies": {
        "@girs/adw-1": "^1.10.0-4.0.0-rc.3",
        "@girs/gjs": "^4.0.0-rc.3",
        "@girs/gtk-4.0": "^4.23.0-4.0.0-rc.3"
    },
    "devDependencies": {
        "@gjsify/cli": "workspace:^",
        "@types/node": "^25.6.0",
        "typescript": "^6.0.2"
    }
}
