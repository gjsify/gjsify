{
    "compilerOptions": {
        "module": "ESNext",
        "target": "ESNext",
        "lib": ["ESNext", "DOM"],
        "rootDir": "src",
        "outDir": "lib",
        "declarationDir": "lib/types",
        "declaration": true,
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "emitDeclarationOnly": true,
        "strict": false
    },
    "include": ["src/**/*.ts"]
}
