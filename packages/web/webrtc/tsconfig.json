{
  "compilerOptions": {
    "module": "ESNext",
    "types": [
      "node",
      "@girs/gjs",
      "@girs/gst-1.0",
      "@girs/gstsdp-1.0",
      "@girs/gstwebrtc-1.0",
      "@girs/glib-2.0",
      "@girs/gobject-2.0"
    ],
    "target": "ESNext",
    "experimentalDecorators": true,
    "emitDeclarationOnly": true,
    "declaration": true,
    "outDir": "lib",
    "rootDir": "src",
    "declarationDir": "lib/types",
    "composite": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,
    "strict": false
  },
  "reflection": false,
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/test.ts",
    "src/test.mts"
  ]
}
