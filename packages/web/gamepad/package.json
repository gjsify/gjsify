{
    "name": "@gjsify/gamepad",
    "version": "0.4.0",
    "description": "Gamepad Web API for GJS using libmanette as backend",
    "type": "module",
    "module": "lib/esm/index.js",
    "types": "lib/types/index.d.ts",
    "exports": {
        ".": {
            "types": "./lib/types/index.d.ts",
            "default": "./lib/esm/index.js"
        },
        "./register": {
            "types": "./lib/types/register.d.ts",
            "default": "./lib/esm/register.js"
        }
    },
    "sideEffects": [
        "./lib/esm/register.js"
    ],
    "scripts": {
        "clear": "rm -rf lib tsconfig.tsbuildinfo tsconfig.types.tsbuildinfo test.gjs.mjs || exit 0",
        "check": "tsc --noEmit",
        "build": "npm run build:gjsify && npm run build:types",
        "build:gjsify": "gjsify build --library 'src/**/*.{ts,js}' --exclude 'src/**/*.spec.{mts,ts}' 'src/test.{mts,ts}'",
        "build:types": "tsc",
        "build:test": "npm run build:test:gjs",
        "build:test:gjs": "gjsify build src/test.mts --app gjs --outfile test.gjs.mjs",
        "test": "npm run build:gjsify && npm run build:test && npm run test:gjs",
        "test:gjs": "gjsify run test.gjs.mjs"
    },
    "keywords": [
        "gjs",
        "gamepad",
        "libmanette",
        "controller"
    ],
    "dependencies": {
        "@gjsify/dom-events": "workspace:^"
    },
    "devDependencies": {
        "@girs/gjs": "4.0.0-rc.15",
        "@girs/glib-2.0": "2.88.0-4.0.0-rc.15",
        "@girs/manette-0.2": "0.2.13-4.0.0-rc.15",
        "@gjsify/cli": "workspace:^",
        "@gjsify/unit": "workspace:^",
        "@types/node": "^25.6.2",
        "typescript": "^6.0.3"
    }
}
