{
  "compilerOptions": {
    "module": "NodeNext",
    "types": ["node"],
    "target": "ESNext",
    "moduleResolution": "NodeNext",
    "experimentalDecorators": true,
    "outDir": "lib",
    "rootDir": "src",
    "composite": true,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "paths": {
      "fetch": ["./src/index.ts"]
    }
  },
  "reflection": false,
  "include": ["src/**/*.ts"],
  "exclude": ["src/test.mts"]
}