{
  "compilerOptions": {
    "rootDir": "src/ts",
    "outDir": "lib",
    "declarationDir": "lib/types",
    "tsBuildInfoFile": "tmp/.tsbuildinfo",
    "target": "es2020",
    "declaration": true,
    "emitDeclarationOnly": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "removeComments": false,
    "preserveConstEnums": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "composite": true,
    "incremental": true,
    "typeRoots": [
      "node_modules",
      "src/ts/@types"
    ],
    "lib": [
      "es2015",
      "es2016",
      "es2017",
      "DOM"
    ],
    "strict": false
  },
  "reflection": false,
  "include": [
    "src/ts/**/*.ts"
  ],
  "exclude": [
    "src/ts/test.ts",
    "src/ts/**/*.spec.ts"
  ]
}
