{
    "name": "@gjsify/web-polyfills",
    "version": "0.3.6",
    "description": "Meta package: all @gjsify Web API polyfill packages as dependencies",
    "type": "module",
    "keywords": [
        "gjs",
        "gjsify",
        "web",
        "polyfills",
        "meta"
    ],
    "dependencies": {
        "@gjsify/abort-controller": "workspace:^",
        "@gjsify/compression-streams": "workspace:^",
        "@gjsify/dom-events": "workspace:^",
        "@gjsify/dom-exception": "workspace:^",
        "@gjsify/domparser": "workspace:^",
        "@gjsify/eventsource": "workspace:^",
        "@gjsify/fetch": "workspace:^",
        "@gjsify/formdata": "workspace:^",
        "@gjsify/gamepad": "workspace:^",
        "@gjsify/web-globals": "workspace:^",
        "@gjsify/web-streams": "workspace:^",
        "@gjsify/webassembly": "workspace:^",
        "@gjsify/webaudio": "workspace:^",
        "@gjsify/webcrypto": "workspace:^",
        "@gjsify/websocket": "workspace:^",
        "@gjsify/webstorage": "workspace:^",
        "@gjsify/xmlhttprequest": "workspace:^"
    }
}
