{
  "compilerOptions": {
    "module": "NodeNext",
    "types": ["node", "@girs/glib-2.0", "@girs/gio-2.0", "@girs/gjs"],
    "target": "ESNext",
    "moduleResolution": "NodeNext",
    "experimentalDecorators": true,
    "outDir": "lib",
    "rootDir": "src",
    "composite": true,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,
    "strict": false
  },
  "reflection": false,
  "include": ["src/**/*.ts"],
  "exclude": []
}
