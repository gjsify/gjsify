{
    "name": "@gjsify/web-globals",
    "version": "0.3.3",
    "description": "Unified Web API globals for GJS — single import for all Web standard polyfills",
    "module": "lib/esm/index.js",
    "types": "lib/types/index.d.ts",
    "exports": {
        ".": {
            "types": "./lib/types/index.d.ts",
            "default": "./lib/esm/index.js"
        },
        "./register": {
            "types": "./lib/types/register.d.ts",
            "default": "./lib/esm/register.js"
        },
        "./register/performance": {
            "default": "./lib/esm/register/performance.js"
        },
        "./register/formdata": {
            "default": "./lib/esm/register/formdata.js"
        }
    },
    "sideEffects": [
        "./lib/esm/register.js",
        "./lib/esm/register/*.js"
    ],
    "scripts": {
        "clear": "rm -rf lib tsconfig.tsbuildinfo tsconfig.types.tsbuildinfo test.gjs.mjs test.node.mjs || exit 0",
        "check": "tsc --noEmit",
        "build": "yarn build:gjsify && yarn build:types",
        "build:gjsify": "gjsify build --library 'src/**/*.{ts,js}' --exclude 'src/**/*.spec.{mts,ts}' 'src/test.{mts,ts}'",
        "build:types": "tsc",
        "build:test": "yarn build:test:gjs",
        "build:test:gjs": "gjsify build src/test.mts --app gjs --outfile test.gjs.mjs",
        "test": "yarn build:gjsify && yarn build:test && yarn test:gjs",
        "test:gjs": "gjsify run test.gjs.mjs"
    },
    "keywords": [
        "gjs",
        "web-globals",
        "polyfill",
        "web-apis"
    ],
    "dependencies": {
        "@gjsify/abort-controller": "workspace:^",
        "@gjsify/buffer": "workspace:^",
        "@gjsify/compression-streams": "workspace:^",
        "@gjsify/dom-events": "workspace:^",
        "@gjsify/dom-exception": "workspace:^",
        "@gjsify/eventsource": "workspace:^",
        "@gjsify/formdata": "workspace:^",
        "@gjsify/gamepad": "workspace:^",
        "@gjsify/perf_hooks": "workspace:^",
        "@gjsify/url": "workspace:^",
        "@gjsify/web-streams": "workspace:^",
        "@gjsify/webaudio": "workspace:^",
        "@gjsify/webcrypto": "workspace:^"
    },
    "devDependencies": {
        "@gjsify/cli": "workspace:^",
        "@gjsify/unit": "workspace:^",
        "@types/node": "^25.6.0",
        "typescript": "^6.0.3"
    }
}
