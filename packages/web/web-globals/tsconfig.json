{
  "compilerOptions": {
    "module": "NodeNext",
    "types": [
      "node"
    ],
    "target": "ESNext",
    "moduleResolution": "NodeNext",
    "experimentalDecorators": true,
    "emitDeclarationOnly": true,
    "declaration": true,
    "outDir": "lib",
    "rootDir": "src",
    "declarationDir": "lib/types",
    "composite": true,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": false,
    "strict": false
  },
  "reflection": false,
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/test.ts",
    "src/test.mts"
  ]
}
