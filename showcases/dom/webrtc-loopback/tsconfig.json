{
  "compilerOptions": {
    "module": "NodeNext",
    "lib": ["ESNext", "DOM"],
    "types": ["node", "@girs/gjs", "@girs/glib-2.0"],
    "target": "ESNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "strict": false
  },
  "include": ["src/**/*.ts"]
}
