{
  "name": "@gjsify/example-dom-canvas2d-fireworks",
  "version": "0.1.11",
  "description": "Colorful fireworks Canvas 2D example with Adwaita controls, adapted from https://codepen.io/juliangarnier/pen/gmOwJX",
  "main": "dist/gjs.js",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    "./browser": "./src/browser/browser.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "clear": "rm -rf dist tsconfig.tsbuildinfo",
    "check": "tsc --noEmit --skipLibCheck --strictNullChecks false --noImplicitAny false",
    "start": "gjsify run dist/gjs.js",
    "start:browser": "http-server dist",
    "build": "yarn build:gjs && yarn build:browser && yarn build:assets",
    "build:gjs": "gjsify build src/gjs/gjs.ts --app gjs --outfile dist/gjs.js",
    "build:browser": "gjsify build src/browser/browser-main.ts --app browser --outfile dist/browser.js",
    "build:assets": "cp -f src/browser/index.html dist/index.html && cp -f src/browser/canvas2d.css dist/canvas2d.css"
  },
  "devDependencies": {
    "@girs/adw-1": "^1.10.0-4.0.0-rc.2",
    "@girs/gio-2.0": "^2.88.0-4.0.0-rc.2",
    "@girs/gjs": "^4.0.0-rc.2",
    "@girs/gobject-2.0": "^2.88.0-4.0.0-rc.2",
    "@girs/gtk-4.0": "^4.23.0-4.0.0-rc.2",
    "@gjsify/adwaita-web": "workspace:^",
    "@gjsify/canvas2d": "workspace:^",
    "@gjsify/cli": "workspace:^",
    "@types/node": "^25.6.0",
    "http-server": "^14.1.1",
    "typescript": "^6.0.2"
  },
  "author": "Pascal Garber <pascal@artandcode.studio>",
  "license": "MIT"
}
