{
  "name": "@gjsify/example-dom-three-geometry-teapot",
  "version": "0.3.0",
  "description": "Three.js geometry teapot example ported from refs/three/examples/webgl_geometry_teapot.html with Adwaita controls",
  "main": "dist/gjs.js",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    "./browser": "./src/browser/browser.ts",
    "./three-demo": "./src/three-demo.ts",
    "./assets/*": "./src/assets/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "clear": "rm -rf dist tsconfig.tsbuildinfo",
    "check": "tsc --noEmit --skipLibCheck --strictNullChecks false --noImplicitAny false",
    "start": "gjsify run dist/gjs.js",
    "start:browser": "http-server dist",
    "build": "yarn build:gjs && yarn build:browser && yarn build:assets",
    "build:gjs": "gjsify build src/gjs/gjs.ts --app gjs --outfile dist/gjs.js",
    "build:browser": "gjsify build src/browser/browser-main.ts --app browser --outfile dist/browser.js",
    "build:assets": "cp -f src/browser/index.html dist/index.html && cp -f src/browser/webgl.css dist/webgl.css && cp -rf src/assets dist/assets"
  },
  "dependencies": {
    "@gjsify/webgl": "workspace:^"
  },
  "devDependencies": {
    "@girs/adw-1": "^1.10.0-4.0.0-rc.9",
    "@girs/gio-2.0": "^2.88.0-4.0.0-rc.9",
    "@girs/gjs": "^4.0.0-rc.9",
    "@girs/gobject-2.0": "^2.88.0-4.0.0-rc.9",
    "@girs/gtk-4.0": "^4.23.0-4.0.0-rc.9",
    "@gjsify/adwaita-web": "workspace:^",
    "@gjsify/cli": "workspace:^",
    "@types/node": "^25.6.0",
    "@types/three": "^0.184.0",
    "http-server": "^14.1.1",
    "three": "0.184.0",
    "typescript": "^6.0.3"
  },
  "author": "Pascal Garber <pascal@artandcode.studio>",
  "license": "MIT"
}
