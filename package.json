{
  "name": "gjsify",
  "version": "0.1.1",
  "description": "The full JavaScript ecosystem, native on GNOME",
  "type": "module",
  "private": true,
  "keywords": [
    "gjs",
    "typescript"
  ],
  "scripts": {
    "test": "yarn workspaces foreach -v --no-private --all --exclude '@girs/*' run test",
    "test:examples": "yarn workspaces foreach -ptv -A --include '@gjsify/example-cli-*' run test",
    "test:examples:net": "yarn workspaces foreach -tv -A --include '@gjsify/example-net-*' run test",
    "test:e2e": "node --test tests/e2e/create-app/run.mjs",
    "check": "yarn workspaces foreach -ptv --all --exclude '@girs/*' run check",
    "check:examples": "yarn workspaces foreach -ptv -A --include '@gjsify/example-*' run check",
    "clear": "yarn workspaces foreach -v --no-private --all --parallel run clear",
    "clear:examples": "yarn workspaces foreach -v -A -p --include '@gjsify/example-*' run clear",
    "npm:publish": "yarn run build && yarn workspaces foreach -v --all --no-private --exclude '@girs/*' npm publish --tolerate-republish --tag latest --access public",
    "build": "yarn run build:infra && yarn workspaces foreach --topological -p --no-private --all --exclude '@girs/*' run build",
    "build:infra": "yarn workspaces foreach -pR --topological-dev --from '@gjsify/cli' run build",
    "build:examples": "yarn workspaces foreach -ptv -A --include '@gjsify/example-*' run build"
  },
  "author": "Pascal Garber <pascal@artandcode.studio>",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^6.0.2"
  },
  "resolutions": {
    "@gjsify/esbuild-plugin-deepkit": "workspace:^"
  },
  "packageManager": "yarn@4.13.0",
  "workspaces": [
    "packages/infra/*",
    "packages/gjs/*",
    "packages/node/*",
    "packages/web/*",
    "packages/dom/*",
    "examples/cli/*",
    "examples/gtk/*",
    "examples/net/*"
  ]
}
