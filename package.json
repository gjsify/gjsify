{
  "name": "gjsify",
  "version": "0.0.4",
  "description": "Combine the power of Typescript with the power of GJS",
  "type": "module",
  "private": true,
  "keywords": [
    "gjs",
    "typescript"
  ],
  "scripts": {
    "test": "yarn workspaces foreach -v --no-private --all --exclude '@girs/*' run test",
    "check": "yarn workspaces foreach -ptv --all --exclude '@girs/*' run check",
    "clear": "yarn workspaces foreach -v --no-private --all --parallel run clear",
    "npm:publish": "yarn run build && yarn workspaces foreach -v --no-private npm publish --tolerate-republish --tag latest --access public",
    "build": "yarn run build:infra && yarn run build:native-libs && yarn run build:gjs && yarn run build:node && yarn run build:web",
    "build:infra": "yarn workspaces foreach -pR --topological-dev --from '@gjsify/cli' run build",
    "build:native-libs": "(yarn workspace @gjsify/webgl run build:meson || true) && yarn workspace @gjsify/types run build",
    "build:gjs": "yarn workspaces foreach -ptR --no-private --from '{@gjsify/utils,@gjsify/unit}' run build",
    "build:web": "yarn workspaces foreach -ptR --no-private --from '{@gjsify/abort-controller,@gjsify/dom-events,@gjsify/formdata,@gjsify/fetch,@gjsify/web-globals,@gjsify/html-image-element}' run build",
    "build:node": "yarn workspaces foreach -ptR --no-private --from '{@gjsify/assert,@gjsify/buffer,@gjsify/console,@gjsify/events,@gjsify/fs,@gjsify/node-globals,@gjsify/http,@gjsify/net,@gjsify/os,@gjsify/path,@gjsify/process,@gjsify/querystring,@gjsify/require,@gjsify/stream,@gjsify/string_decoder,@gjsify/tty,@gjsify/url,@gjsify/util,@gjsify/zlib}' run build"
  },
  "author": "Pascal Garber <pascal@artandcode.studio>",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "resolutions": {
    "@gjsify/esbuild-plugin-deepkit": "workspace:^"
  },
  "packageManager": "yarn@4.13.0",
  "workspaces": [
    "packages/infra/*",
    "packages/gjs/*",
    "packages/gjs/types/@types/gwebgl-0.1",
    "packages/node/*",
    "packages/web/*",
    "examples/*"
  ]
}
