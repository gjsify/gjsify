# Yarn https://yarnpkg.com/getting-started/qa#which-files-should-be-gitignored
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

*.tsbuildinfo

node_modules/
tmp/
dist/
dist-templates/
lib/
build/
builddir/

# Phase D.7b: the gjsify CLI's GJS bundle is committed so CI (and
# downstream consumers) can bootstrap via `gjs -m cli.gjs.mjs …`
# without Node. Refreshed by `yarn workspace @gjsify/cli run
# build:gjs-bundle` on every CLI source change; a staleness check
# in CI forces a refresh-commit when src/ changes without the
# bundle being rebuilt.
!packages/infra/cli/dist/
!packages/infra/cli/dist/cli.gjs.mjs

packages/**/*/test.*.js
packages/**/*/test.*.js.map
packages/**/*/test.*.cjs
packages/**/*/test.*.cjs.map
packages/**/*/test.*.mjs
packages/**/*/test.*.mjs.map
packages/**/*/conformance.*.js
packages/**/*/conformance.*.js.map

examples/**/*/test.*.js
examples/**/*/test.*.js.map
examples/**/*/test.*.cjs
examples/**/*/test.*.cjs.map
examples/**/*/test.*.mjs
examples/**/*/test.*.mjs.map

# Test artifacts (fs tests create temp dirs/files)
fs-*/
foobar/
symlink_tsconfig.json

# Ad-hoc test/debug scripts in project root
test-*.mjs
test-*.js

# Metafile
*.meta.json
meta.json

# Astro
.astro/

# E2E test artifacts
tests/e2e/*/out/
